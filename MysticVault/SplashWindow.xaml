<Window x:Class="MysticVault.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MysticVault" Height="350" Width="450"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.5"/>
        </Storyboard>
    </Window.Resources>
    <Border Background="#1E1E1E" CornerRadius="12" BorderBrush="#333" BorderThickness="1" Opacity="0" x:Name="MainBorder">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Ensure an icon exists, we use a default text if the image fails but WPF ignores missing images nicely -->
            <TextBlock Text="🔒" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="MysticVault" FontSize="32" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="Initializing Cryptography Core..." FontSize="14" Foreground="#888" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            <ProgressBar x:Name="LoadingBar" Width="200" Height="4" Margin="0,25,0,0" IsIndeterminate="True" 
                         Background="#333" Foreground="#007ACC" BorderThickness="0"/>
        </StackPanel>
    </Border>
</Window>
