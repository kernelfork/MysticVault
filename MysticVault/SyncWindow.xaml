<Window x:Class="MysticVault.SyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Local Wi-Fi Sync" Height="500" Width="450"
        WindowStartupLocation="CenterOwner" Background="#1E1E1E" Foreground="White"
        BorderBrush="#333" BorderThickness="1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Scan this QR code with your phone camera to securely sync your vault over local Wi-Fi." TextWrapping="Wrap" FontSize="16" TextAlignment="Center" Margin="0,0,0,20"/>
        
        <Image x:Name="QrImage" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Margin="20"/>
        
        <TextBlock Grid.Row="2" Text="Ensure your phone and PC are on the exact same Wi-Fi network. Do not close this window until your phone finishes downloading the vault." TextWrapping="Wrap" FontSize="14" Foreground="#888" TextAlignment="Center" Margin="0,20,0,0"/>
    </Grid>
</Window>
