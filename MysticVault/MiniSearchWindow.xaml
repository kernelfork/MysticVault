<Window x:Class="MysticVault.MiniSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto-Type Search" Height="450" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="Manual" Topmost="True" ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border Background="#F51E1E1E" CornerRadius="12" BorderBrush="#444" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBox x:Name="SearchBox" Grid.Row="0" Margin="0,0,0,10" 
                     TextChanged="SearchBox_TextChanged"
                     PreviewKeyDown="SearchBox_PreviewKeyDown"
                     Background="#2D2D30" Foreground="White" BorderThickness="0" Padding="10" FontSize="16"/>
                     
            <ListBox x:Name="ResultsList" Grid.Row="1" 
                     Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14"
                     DisplayMemberPath="Key"
                     PreviewKeyDown="ResultsList_PreviewKeyDown"
                     MouseDoubleClick="ResultsList_MouseDoubleClick"/>
        </Grid>
    </Border>
</Window>
